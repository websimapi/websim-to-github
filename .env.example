# GitHub OAuth App credentials
# Create one at: https://github.com/settings/developers → OAuth Apps → New OAuth App
# Set callback URL to: https://your-app.onrender.com/auth/github/callback
GITHUB_CLIENT_ID=your_client_id_here
GITHUB_CLIENT_SECRET=your_client_secret_here

# Random string for signing session cookies — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_this_to_a_random_string

# Production URL (used to build OAuth redirect URI)
# Leave blank for localhost dev (defaults to http://localhost:3000)
APP_URL=
